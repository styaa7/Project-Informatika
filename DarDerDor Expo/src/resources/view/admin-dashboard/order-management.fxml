<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="850" prefWidth="1400" stylesheets="@../../css/admin-dashboard.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="craftflow.controller.admin.OrderManagementController">

    <!-- ========================= SIDEBAR ========================= -->
    <left>
        <VBox styleClass="sidebar">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label style="-fx-text-fill: #2f6fed; -fx-font-size: 18px;" />
                <Label styleClass="logo-text" text="CraftFlow" />
            </HBox>

            <Region prefHeight="25" />

            <VBox spacing="6">
                <Button maxWidth="Infinity" onAction="#goDashboard" styleClass="nav-item" text="Dashboard" />
                <Button maxWidth="Infinity" onAction="#goOrder" styleClass="nav-item-active" text="Order" />
                <Button maxWidth="Infinity" onAction="#goProduct" styleClass="nav-item" text="Product" />
                <Button maxWidth="Infinity" onAction="#goCustomer" styleClass="nav-item" text="null" />
                <Button maxWidth="Infinity" onAction="#goEmployee" styleClass="nav-item" text="null" />
                <Button maxWidth="Infinity" onAction="#goBilling" styleClass="nav-item" text="null" />
                <Button maxWidth="Infinity" onAction="#goAnalytics" styleClass="nav-item" text="null" />
                <Button maxWidth="Infinity" onAction="#goSetting" styleClass="nav-item" text="Setting  " />
                <Button maxWidth="Infinity" onAction="#goHelp" styleClass="nav-item" text="Help" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <Separator />
            <Button maxWidth="Infinity" onAction="#handleLogout" styleClass="nav-logout" text="Log out" />
        </VBox>
    </left>

    <!-- ========================= MAIN CONTENT ========================= -->
    <center>
        <VBox spacing="20" style="-fx-padding: 25;">

            <!-- ===== Top Bar ===== -->
            <HBox alignment="CENTER_LEFT" spacing="15">
                <TextField fx:id="txtSearch" prefWidth="400" promptText="🔍  Search" styleClass="search-field" />
                <Region HBox.hgrow="ALWAYS" />
                <StackPane styleClass="icon-btn"><Label text="✉" /></StackPane>
                <StackPane styleClass="icon-btn"><Label text="🔔" /></StackPane>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <StackPane styleClass="avatar-circle" />
                    <VBox spacing="2">
                        <Label styleClass="user-name" text="Jane Cooper" />
                        <Label styleClass="user-email" text="jane234@example.com" />
                    </VBox>
                    <Label style="-fx-text-fill: #9aa0ac;" />
                </HBox>
            </HBox>

            <!-- ===== Content Card ===== -->
            <VBox spacing="20" styleClass="content-card" VBox.vgrow="ALWAYS">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label styleClass="page-title" text="Order" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button onAction="#handleDeleteOrder" style="-fx-background-color: red;" styleClass="btn-primary" text="Delete Order" />
               <Button layoutX="941.0" layoutY="10.0" onAction="#handleUpdateOrder" styleClass="btn-primary" text="Update Order" />
               <Button layoutX="781.0" layoutY="10.0" onAction="#handleAddOrder" styleClass="btn-primary" text="Add New Order" />
                </HBox>

                <TableView fx:id="tableOrder" styleClass="data-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="tcOrderId" prefWidth="110" text="Order ID" />
                        <TableColumn fx:id="tcCustomerName" prefWidth="180" text="Customer" />
                        <TableColumn fx:id="tcProduct" prefWidth="200" text="Product" />
                        <TableColumn fx:id="tcDate" prefWidth="110" text="Date" />
                        <TableColumn fx:id="tcTotal" prefWidth="100" text="Total" />
                        <TableColumn fx:id="tcStatus" prefWidth="130" text="Status" />
                    </columns>
                </TableView>

                <HBox alignment="CENTER" spacing="10">
               <ComboBox fx:id="statusBox" prefWidth="200.0" promptText="Status" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Region HBox.hgrow="ALWAYS" />
                </HBox>

            </VBox>
        </VBox>
    </center>

</BorderPane>
